{
  "name": "legalai-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:desktop": "pnpm --filter legalai-desktop dev",
    "build:desktop": "pnpm --filter legalai-desktop build",
    "build": "pnpm -r build",
