# Legal AI MVP - 环境变量配置示例
# 复制为 .env 后修改实际值

# ===========================================
# iii 引擎（必需）
# ===========================================
III_ENGINE_URL=ws://localhost:49134
ENGINE_URL=ws://localhost:49134
# III 内部隔离模式（false = 绕过 Docker sandbox，直接本地执行 harness bundle）
III_ISOLATION=false
# OpenTelemetry 开关（false = 禁用，避免外部 API 调用报 fetch failed）
OTEL_ENABLED=false

# ===========================================
# 数据库（必需）
# ===========================================
DATABASE_URL=postgresql://postgres:legalai123@localhost:5432/legalai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legalai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=legalai123

# ===========================================
# Redis（必需）
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# LLM 提供商配置
# ===========================================
# 支持: siliconflow (默认), deepseek, minimax, openai, anthropic
LLM_PROVIDER=siliconflow
LLM_API_KEY=your-api-key-here

# OpenAI / SiliconFlow (SiliconFlow uses OpenAI-compatible API)
# SiliconFlow API: https://api.siliconflow.cn/v1/chat/completions
OPENAI_API_KEY=your-siliconflow-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
CLAUDE_API_KEY=your-claude-key-here

# SiliconFlow
SILICONFLOW_API_KEY=your-siliconflow-key-here

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key-here

# ===========================================
# Embedding 模型
# ===========================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===========================================
# 文件存储
# ===========================================
FILE_STORAGE_PATH=./uploads
MAX_FILE_SIZE=52428800

# ===========================================
# 服务器
# ===========================================
PORT=3111
NODE_ENV=development
