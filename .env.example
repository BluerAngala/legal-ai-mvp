# LegalAI MVP - Environment Variables Example
# Copy this file to .env and fill in your values

# PostgreSQL Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legalai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=legalai123

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Database URL (alternative to individual settings)
# DATABASE_URL=postgresql://postgres:legalai123@localhost:5432/legalai

# OpenAI API (for embeddings)
OPENAI_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Claude API (for LLM analysis)
CLAUDE_API_KEY=sk-ant-your-claude-api-key

# File Storage
FILE_STORAGE_PATH=./uploads

# Engine URL (for iii)
ENGINE_URL=http://localhost:4000

# Server Configuration
PORT=3000
NODE_ENV=development
